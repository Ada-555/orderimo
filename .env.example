# Plurino — Environment Variables Template
# Copy this to .env and fill in your values

# ─── Django ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (Supabase) ────────────────────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Connection String → URI
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys (use test keys for dev)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cloudflare R2 (Storage) ────────────────────────────────────────────────
# R2 is S3-compatible, free 5GB. Get from: Cloudflare Dashboard → R2
USE_R2=False
R2_BUCKET_NAME=plurino-storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key

# ─── Email ──────────────────────────────────────────────────────────────────
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ─── E-Commerce ─────────────────────────────────────────────────────────────
FREE_DELIVERY_THRESHOLD=80.00
STANDARD_DELIVERY_PERCENTAGE=15

# ─── CORS (if using API separately) ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
